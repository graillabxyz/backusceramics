// Backus Ceramics — Database Schema
// Prisma + SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// NextAuth.js required models
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // "USER" | "ADMIN"

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  classBookings ClassBooking[]
  residencyApps ResidencyApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Application models
// ============================================================

model Order {
  id     String @id @default(cuid())
  status String @default("INQUIRY")
  // Status values: INQUIRY, REVIEWING, QUOTED, ACCEPTED,
  //   IN_PROGRESS, GLAZING, FIRING, COMPLETED, SHIPPED, CANCELLED

  // Contact snapshot
  contactName     String
  contactEmail    String
  contactPhone    String?
  contactLocation String

  // Order data stored as JSON strings
  pieces      String // JSON array of piece objects
  preferences String // JSON object of preferences

  // Relations
  userId  String?
  user    User?         @relation(fields: [userId], references: [id])
  updates OrderUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderUpdate {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  title       String
  description String?
  images      String? // JSON array of image URLs

  createdAt DateTime @default(now())
}

model ClassBooking {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  workshopId String // References classes-data.ts workshop ID
  status     String @default("PENDING")
  // Status values: PENDING, CONFIRMED, COMPLETED, CANCELLED

  // Booking details
  preferredDate String?
  participants  Int     @default(1)
  notes         String?

  // Contact snapshot
  contactName  String
  contactEmail String
  contactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResidencyApplication {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  programId String // References classes-data.ts residency ID
  status    String @default("SUBMITTED")
  // Status values: SUBMITTED, UNDER_REVIEW, ACCEPTED, WAITLISTED, DECLINED, CANCELLED

  // Application details
  experience    String?
  goals         String?
  preferredDate String?
  notes         String?

  // Contact snapshot
  contactName  String
  contactEmail String
  contactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
