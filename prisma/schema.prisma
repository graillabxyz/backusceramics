// Backus Ceramics — Database Schema
// Prisma + SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// NextAuth.js required models
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // "USER" | "MANAGER" | "ADMIN" | "OWNER" | "POS_OPERATOR"

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  classBookings ClassBooking[]
  classHolds    ClassHold[]
  classSchedules ClassSchedule[]
  posProducts    PosProduct[] @relation("PosProductCreator")
  posSales       PosSale[] @relation("PosSaleOperator")
  voidedPosSales PosSale[] @relation("PosSaleVoider")
  analyticsEvents AnalyticsEvent[]
  residencyApps ResidencyApplication[]
  notificationPreference UserNotificationPreference?
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Application models
// ============================================================

model Order {
  id     String @id @default(cuid())
  status String @default("INQUIRY")
  // Status values: INQUIRY, REVIEWING, QUOTED, ACCEPTED,
  //   IN_PROGRESS, GLAZING, FIRING, COMPLETED, SHIPPED, CANCELLED

  // Contact snapshot
  contactName     String
  contactEmail    String
  contactPhone    String?
  contactLocation String

  // Order data stored as JSON strings
  pieces      String // JSON array of piece objects
  preferences String // JSON object of preferences

  // Relations
  userId  String?
  user    User?         @relation(fields: [userId], references: [id])
  updates OrderUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderUpdate {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  title       String
  description String?
  images      String? // JSON array of image URLs

  createdAt DateTime @default(now())
}

model ClassBooking {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  workshopId String // References classes-data.ts workshop ID
  scheduleId  String?
  schedule    ClassSchedule? @relation(fields: [scheduleId], references: [id])
  status     String @default("PENDING")
  // Status values: PENDING, CONFIRMED, COMPLETED, CANCELLED

  // Booking details
  preferredDate String?
  participants  Int     @default(1)
  notes         String?
  paymentReference String?
  paymentSessionId String?
  holdExpiresAt DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  archivedAt DateTime?

  // Contact snapshot
  contactName  String
  contactEmail String
  contactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentReference])
  @@index([paymentSessionId])
  @@index([status, holdExpiresAt])
  @@index([status, archivedAt])
}

model ClassSchedule {
  id        String @id @default(cuid())
  createdBy String?
  creator   User?  @relation(fields: [createdBy], references: [id])

  offeringId      String
  title           String
  category        String @default("class")
  status          String @default("ACTIVE")
  // Status values: ACTIVE, PAUSED, CANCELLED
  timeLabel       String
  startDate       DateTime
  endDate         DateTime?
  weekdays        String? // JSON array of day indexes for recurring schedules
  maxParticipants Int
  notes           String?

  bookings ClassBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offeringId, startDate, endDate])
  @@index([status])
}

model ClassHold {
  id        String @id @default(cuid())
  createdBy String?
  creator   User?  @relation(fields: [createdBy], references: [id])

  studentName  String
  studentEmail String?
  workshopId   String
  timeLabel    String
  seats        Int    @default(1)
  weekdays     String // JSON array of day indexes, 0 = Sunday
  startDate    DateTime
  endDate      DateTime?
  notes        String?
  status       String @default("ACTIVE")
  // Status values: ACTIVE, PAUSED, CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workshopId, startDate, endDate])
  @@index([status])
}

model PosProduct {
  id        String @id @default(cuid())
  createdBy String?
  creator   User?  @relation("PosProductCreator", fields: [createdBy], references: [id])

  name        String
  slug        String  @unique
  sku         String?
  description String?
  volumeMl    Int?
  imageUrls   String? // JSON array of image URLs
  price       Int
  currency    String  @default("IDR")
  category    String
  quantity    Int     @default(1)
  status      String  @default("AVAILABLE")
  // Status values: AVAILABLE, SOLD, DRAFT, ARCHIVED
  cafeOnly   Boolean @default(false)
  showInShop  Boolean @default(false)
  featured   Boolean @default(false)
  sortOrder  Int     @default(0)

  saleItems PosSaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([showInShop])
  @@index([cafeOnly])
  @@index([category])
  @@index([sortOrder])
}

model PosSale {
  id         String @id @default(cuid())
  operatorId String?
  operator  User?  @relation("PosSaleOperator", fields: [operatorId], references: [id])
  voidedById String?
  voidedBy   User?  @relation("PosSaleVoider", fields: [voidedById], references: [id])

  subtotal      Int    @default(0)
  discountTotal Int    @default(0)
  taxTotal      Int    @default(0)
  total         Int
  currency      String @default("IDR")
  status        String @default("PAID")
  // Status values: PAID, PENDING_PAYMENT, CANCELLED, VOIDED
  paymentMethod String @default("CARD_MACHINE")
  paymentReference String?
  paymentSessionId String?
  receiptEmail String?
  receiptSentAt DateTime?
  notes         String?
  voidedAt      DateTime?
  voidReason    String?

  items PosSaleItem[]

  createdAt DateTime @default(now())

  @@index([operatorId])
  @@index([voidedById])
  @@index([createdAt])
  @@index([status])
  @@index([paymentReference])
  @@index([paymentSessionId])
}

model PosSaleItem {
  id        String @id @default(cuid())
  saleId    String
  sale      PosSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String?
  product   PosProduct? @relation(fields: [productId], references: [id])

  nameSnapshot     String
  skuSnapshot      String?
  categorySnapshot String
  unitPrice        Int
  quantity         Int
  subtotal         Int @default(0)
  discountAmount   Int @default(0)
  taxRate          Int @default(0)
  taxAmount        Int @default(0)
  lineTotal        Int

  @@index([saleId])
  @@index([productId])
}

model AdminNotification {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String
  path      String?
  city      String?
  region    String?
  country   String?
  ip        String?
  userAgent String?
  metadata  String?
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}

model UserNotificationPreference {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  browserPushEnabled       Boolean @default(false)
  classBookingNotifications Boolean @default(true)
  salesNotifications        Boolean @default(true)
  websiteVisitNotifications Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String
  userAgent String?
  enabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([enabled])
}

model AnalyticsEvent {
  id        String @id @default(cuid())
  type      String
  path      String?
  referrer  String?
  pageTitle String?

  visitorId String?
  sessionId String?
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  productId       String?
  productSlug     String?
  productName     String?
  productCategory String?

  workshopId    String?
  workshopTitle String?
  scheduleId    String?
  source        String?

  value    Int?
  currency String @default("IDR")
  metadata String?

  city      String?
  region    String?
  country   String?
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([path])
  @@index([userId])
  @@index([visitorId])
  @@index([sessionId])
  @@index([productSlug])
  @@index([workshopId])
  @@index([source])
}

model ResidencyApplication {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  programId String // References classes-data.ts residency ID
  status    String @default("SUBMITTED")
  // Status values: SUBMITTED, UNDER_REVIEW, ACCEPTED, WAITLISTED, DECLINED, CANCELLED

  // Application details
  experience    String?
  goals         String?
  preferredDate String?
  notes         String?

  // Contact snapshot
  contactName  String
  contactEmail String
  contactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
